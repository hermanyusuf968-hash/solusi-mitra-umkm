# ============================================================
# .env.example
# Contoh environment variables untuk deployment Railway
# Salin file ini ke .env untuk development lokal
# Di Railway, set variabel ini di Settings > Variables
# ============================================================

# --- AI Provider ---
# Pilih: "gemini" atau "openai"
AI_PROVIDER=gemini

# --- API Keys (WAJIB, minimal salah satu) ---
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Database ---
# Opsi 1: Gunakan DATABASE_URL langsung (Railway auto-inject jika pakai MySQL plugin)
DATABASE_URL=mysql+pymysql://user:password@host:port/dbname?charset=utf8mb4

# Opsi 2: Set individual (jika tidak pakai DATABASE_URL)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=ai_konsultasi_db

# Opsi 3: Kosongkan semua DB vars → otomatis pakai SQLite lokal (dev only)

# --- CORS ---
# Pisahkan multiple origins dengan koma
CORS_ALLOWED_ORIGINS=https://suksesmitraumkm.vercel.app,http://localhost:3000

# --- Port (Railway auto-inject, jangan set manual di Railway) ---
# PORT=8000
